# Copy to .env.local for local dev. Never commit real secrets.
# Next.js auto-loads .env.local without explicit opt-in.
#
# For Vercel deployments, set the same keys in
# Settings -> Environment Variables. See DEPLOY.md at the repo root for
# the full list and step-by-step UI walkthrough.

# --- Backend API ---
# Local FastAPI on uvicorn. The frontend-only Vercel deploy points at
# `http://localhost:8000`; modern browsers (Chrome / Firefox) treat
# localhost as a secure context and allow the cross-origin fetch from
# https://*.vercel.app, but each visitor must have the API running on
# their own machine. See SETUP.md.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Optional: explicit canonical URL. Used for `metadataBase` and OG
# previews. If unset on Vercel we fall back to VERCEL_PROJECT_PRODUCTION_URL
# (prod) and VERCEL_URL (previews) automatically.
# NEXT_PUBLIC_SITE_URL=https://vela.example.com

# --- Clerk auth ---
# From dashboard.clerk.com -> your app -> "API Keys".
# IMPORTANT: after first deploy, add your Vercel URL to the Clerk
# dashboard under Settings -> Domains so sign-in succeeds in production.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME
CLERK_SECRET_KEY=sk_test_REPLACE_ME

# Optional: Clerk redirect overrides. Defaults send signed-out users to
# /sign-in and post-sign-in users back to /.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/onboarding
