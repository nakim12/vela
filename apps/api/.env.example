# Copy to .env for local dev. Never commit real secrets.

# --- Database ---
# Local Postgres (matches infra/docker-compose.yml). If unset, the API falls
# back to a SQLite file at apps/api/vela.db.
DATABASE_URL=postgresql+psycopg://vela:vela@localhost:5432/vela

# --- Agent / LLM ---
BACKBOARD_API_KEY=

LLM_PROVIDER=anthropic
LLM_MODEL_NAME=claude-sonnet-4-5

APP_ENV=development
