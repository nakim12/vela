# Copy to .env for local dev. Never commit real secrets.

# --- Database ---
# Local Postgres (matches infra/docker-compose.yml). If unset, the API falls
# back to a SQLite file at apps/api/vela.db.
DATABASE_URL=postgresql+psycopg://vela:vela@localhost:5432/vela

# --- Agent / LLM ---
BACKBOARD_API_KEY=

LLM_PROVIDER=anthropic
LLM_MODEL_NAME=claude-sonnet-4-5

APP_ENV=development

# Populated after the first run of `python -m scripts.upload_corpus`.
# Leave blank until then; search_research will fall back to a stub.
CORPUS_ASSISTANT_ID=

# --- Clerk auth ---
# When CLERK_JWT_ISSUER is empty, every request authenticates as
# DEMO_USER_ID so Nathan's smoke scripts + curl against /docs keep working
# without a real sign-in. Production bootstraps MUST set CLERK_JWT_ISSUER
# (FastAPI will raise 401 if app_env=production and issuer is unset).
CLERK_SECRET_KEY=
# From dashboard.clerk.com > API Keys > "Frontend API" (e.g.
# https://trusted-marmoset-42.clerk.accounts.dev). We fetch JWKS from
# {issuer}/.well-known/jwks.json at request time; no manual JWKS download.
CLERK_JWT_ISSUER=
DEMO_USER_ID=demo-user-1
